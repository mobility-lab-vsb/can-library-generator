#include "{{ ir.library_name }}_db.h"

{% for msg in ir.messages %}
// Message: {{ msg.name }}
{%- if msg.signals %}
static can_db_sig_t {{ msg.name }}_signals[] = {
{%- for sig in msg.signals %}
    {
        .name = "{{ sig.name }}",
        .start_bit = {{ sig.start_bit }},
        .length = {{ sig.length }},
        .byte_order = "{{ sig.byte_order }}",
        .value_type = '{{ "s" if sig.is_signed else "u" }}',
        .factor = {{ sig.factor }},
        .offset = {{ sig.offset }},
        .min = {{ sig.minimum }},
        .max = {{ sig.maximum }},
        .unit = "{{ sig.unit }}",
        .receiver = "{{ sig.receivers | join(', ') }}",
        .raw_value = {{ sig.raw_initial }},
        .phys_value = {{ sig.phys_initial }},
        .raw_init = {{ sig.raw_initial }}
    }{%- if not loop.last %},{% endif %}
{%- endfor %}
};
{%- else %}
// No signals for this message
{%- endif %}

can_db_{{ msg.name.replace(' ', '') }}_t {{ ir.library_name }}_{{ msg.name }} = {
    .base = {
        .id = {{ msg.frame_id }},
        .name = "{{ msg.name }}",
        .dlc = {{ msg.dlc }},
        .length = {{ msg.length }},
        .senders = "{{ msg.senders | join(', ') }}",
        .receivers = "{{ msg.receivers | join(', ') }}",
        .num_signals = {{ msg.signals | length }},
         .data = {0},
        .is_fd = {{ 1 if msg.is_fd else 0 }},
        .frame_type = {{ 1 if msg.is_extended else 0 }},
        .cycle_time = {{ msg.cycle_time }},
        .signals = {% if msg.signals|length > 0 %}{{ msg.name }}_signals{% else %}NULL{% endif %}
    },
{%- for sig in msg.signals %}
    .{{ sig.name }} = &{{ msg.name }}_signals[{{ loop.index0 }}]{%- if not loop.last %},{% endif %}
{%- endfor %}
};

{%- endfor %}

// Message registry
can_db_msg_t* const {{ ir.library_name }}_all_messages[] = {
{%- for msg in ir.messages %}
    (can_db_msg_t*)&{{ ir.library_name }}_{{ msg.name }}{%- if not loop.last %},{% endif %}
{%- endfor %}
};

const size_t {{ ir.library_name }}_all_messages_count = {{ ir.messages | length }};