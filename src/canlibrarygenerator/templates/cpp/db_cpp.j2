#include "{{ ir.library_name }}_db.hpp"

{% for msg in ir.messages %}
// Message: {{ msg.name }}
{%- if msg.signals %}
static can_db_sig_t {{ msg.name }}_signals[] = {
{%- for sig in msg.signals %}
    {
        "{{ sig.name }}",
        {{ sig.start_bit }},
        {{ sig.length }},
        "{{ sig.byte_order }}",
        '{{ "s" if sig.is_signed else "u" }}',
        {{ sig.factor }},
        {{ sig.offset }},
        {{ sig.minimum }},
        {{ sig.maximum }},
        "{{ sig.unit }}",
        "{{ sig.receivers | join(', ') }}",
        {{ sig.raw_initial }},
        {{ sig.phys_initial }},
        {{ sig.raw_initial }}
    }{%- if not loop.last %},{% endif %}
{%- endfor %}
};
{%- endif %}

can_db_{{ msg.name.replace(' ', '') }}_t {{ ir.library_name }}_{{ msg.name }} = {
    {
        {{ "0x%X"|format(msg.frame_id) }},
        "{{ msg.name }}",
        {{ msg.dlc }},
        {{ msg.length }},
        "{{ msg.senders | join(', ') }}",
        "{{ msg.receivers | join(', ') }}",
        {{ msg.signals | length }},
        {0},
        {{ "true" if msg.is_fd else "false" }},
        {{ 1 if msg.is_extended else 0 }},
        {{ msg.cycle_time }},
        { {% if msg.signals|length > 0 %}{% for sig in msg.signals %}&{{ msg.name }}_signals[{{ loop.index0 }}]{{ ", " if not loop.last }}{% endfor %}{% endif %} }
    },
{%- for sig in msg.signals %}
    &{{ msg.name }}_signals[{{ loop.index0 }}]{%- if not loop.last %},{% endif %}
{%- endfor %}
};

{%- endfor %}

// Message registry
std::vector<can_db_msg_t*> {{ ir.library_name }}_all_messages = {
{%- for msg in ir.messages %}
    &{{ ir.library_name }}_{{ msg.name }}.base{%- if not loop.last %},{% endif %}
{%- endfor %}
};