uint64_t {{ ir.library_name }}_parse_signal(const uint8_t* data, const uint8_t msg_length, const uint16_t start_bit, const uint8_t length, const std::string& byte_order) {
    uint64_t result = 0;
    if (byte_order == "little_endian") {
        uint8_t byte = start_bit / 8;
        uint8_t bit = start_bit % 8;
        uint8_t bitsRead = 0;
        while (bitsRead < length) {
            uint8_t remainingBitsInByte = 8 - bit;
            uint8_t bitsToRead = std::min((uint8_t)(length - bitsRead), remainingBitsInByte);
            uint8_t mask = (1 << bitsToRead) - 1;
            uint8_t extracted = (data[byte] >> bit) & mask;
            result |= (static_cast<uint64_t>(extracted) << bitsRead);
            bitsRead += bitsToRead;
            bit = 0;
            byte++;
        }
    } else {
        for (uint8_t i = 0; i < length; i++) {
            uint16_t bitOffset = start_bit - i;
            uint8_t byteIndex = bitOffset / 8;
            uint8_t bitInByte = 7 - (bitOffset % 8);
            if (byteIndex < msg_length) {
                uint8_t bit = (data[byteIndex] >> bitInByte) & 0x1;
                result |= (static_cast<uint64_t>(bit) << i);
            }
        }
    }
    return result;
}

int {{ ir.library_name }}_unpackage_message(const uint32_t can_id, const uint8_t* data, const uint8_t msg_length) {
    can_db_msg_t* msg = {{ ir.library_name }}_find_message_by_id(can_id);
    if (!msg || msg->length != msg_length) return -1;

    std::memcpy(msg->data, data, msg_length);
    for (auto* sig : msg->signals) {
        sig->raw_value = {{ ir.library_name }}_parse_signal(msg->data, msg->length, sig->start_bit, sig->length, sig->byte_order);
        if (sig->value_type == 's') {
            int64_t s_val = static_cast<int64_t>(sig->raw_value);
            s_val = (s_val << (64 - sig->length)) >> (64 - sig->length);
            sig->phys_value = (s_val * sig->factor) + sig->offset;
        } else {
            sig->phys_value = (sig->raw_value * sig->factor) + sig->offset;
        }
    }
    return 0;
}

void {{ ir.library_name }}_insert_signal(uint8_t* data, const uint8_t msg_length, const uint32_t raw_value, const int start_bit, const int length, const std::string& byte_order) {
    if (byte_order == "little_endian") {
        for (int i = 0; i < length; i++) {
            int bitIndex = start_bit + i;
            int byteIndex = bitIndex / 8;
            if (byteIndex >= msg_length) continue;
            if ((raw_value >> i) & 1) data[byteIndex] |= (1 << (bitIndex % 8));
            else data[byteIndex] &= ~(1 << (bitIndex % 8));
        }
    } else {
        for (int i = 0; i < length; i++) {
            int bitPos = start_bit - i;
            int byteIndex = bitPos / 8;
            if (byteIndex >= msg_length) continue;
            if ((raw_value >> i) & 1) data[byteIndex] |= (1 << (7 - (bitPos % 8)));
            else data[byteIndex] &= ~(1 << (7 - (bitPos % 8)));
        }
    }
}

int {{ ir.library_name }}_package_message(const uint32_t can_id) {
    can_db_msg_t* msg = {{ ir.library_name }}_find_message_by_id(can_id);
    if (!msg) return -1;
    std::memset(msg->data, 0, msg->length);
    for (auto* sig : msg->signals) {
        sig->raw_value = static_cast<uint64_t>(std::llround((sig->phys_value - sig->offset) / sig->factor));
        {{ ir.library_name }}_insert_signal(msg->data, msg->length, (uint32_t)sig->raw_value, sig->start_bit, sig->length, sig->byte_order);
    }
    return 0;
}

