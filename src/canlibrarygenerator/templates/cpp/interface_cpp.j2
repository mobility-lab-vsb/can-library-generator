void {{ ir.library_name }}_init(can_db_msg_t* msg) {
    if (!msg) return;
    for (auto* sig : msg->signals) {
        sig->raw_value = sig->raw_init;
        sig->phys_value = (sig->raw_value * sig->factor) + sig->offset;
